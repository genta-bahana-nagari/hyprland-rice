{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "foreground": "cyan",
          "style": "powerline",
          "template": "{{ .Icon }}",
          "type": "os"
        },
        {
          "foreground": "cyan",
          "options": {
            "style": "full"
          },
          "style": "plain",
          "template": " {{ .Path }} ",
          "type": "path"
        },
        {
          "foreground": "lightYellow",
          "style": "plain",
          "template": ":: <lightBlue>git(</>{{ .HEAD }}<lightBlue>)</>",
          "type": "git"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground": "lightGreen",
          "foreground_templates": [
            "{{ if gt .Code 0 }}red{{ end }}"
          ],
          "options": {
            "always_enabled": true
          },
          "style": "powerline",
          "template": "\u279c ",
          "type": "status"
        }
      ],
      "type": "prompt"
    }
  ],
  "version": 4
}