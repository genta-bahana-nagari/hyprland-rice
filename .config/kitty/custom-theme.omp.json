{
  "$schema": "https://raw.githubusercontent.com/JanDeDobbeleer/oh-my-posh/main/themes/schema.json",
  "blocks": [
    {
      "alignment": "left",
      "segments": [
        {
          "style": "powerline",
          "template": "{{ .Icon }}",
          "type": "os"
        },
        {
          "options": {
            "style": "full"
          },
          "style": "plain",
          "template": "  {{ .Path }} ",
          "type": "path"
        },
        {
          "style": "plain",
          "template": ":: </>{{ .HEAD }}",
          "type": "git"
        },
        {
          "style": "plain",
          "template": " \ue718 {{ if .PackageManagerIcon }}{{ .PackageManagerIcon }} {{ end }}{{ .Full }} ",
          "type": "node"
        }
      ],
      "type": "prompt"
    },
    {
      "alignment": "left",
      "newline": true,
      "segments": [
        {
          "foreground_templates": ["{{ if gt .Code 0 }} {{ end }}"],
          "options": {
            "always_enabled": true
          },
          "style": "powerline",
          "template": "\u279c ",
          "type": "status"
        }
      ],
      "type": "prompt"
    }
  ],
  "version": 4
}
