{
  "spacing": 18,
  "margin-top": 5,

  "modules-left": ["custom/updatetoggler"],

  "modules-center": [
    "hyprland/workspaces",
    "clock",
    "pulseaudio",
    "network",
    "battery",
  ],

  "modules-right": ["custom/notifications"],

  "custom/updatetoggler": {
    "format": "≤░μΘ",
    "tooltip": false,
    "on-click": "kitty bash -c 'sudo pacman -Syyu; exec bash'",
  },

  "clock": {
    "interval": 60,
    "format": "{:%H:%M}",
    "tooltip": false,
  },

