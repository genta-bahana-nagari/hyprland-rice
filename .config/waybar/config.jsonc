  "pulseaudio": {
    "format": "{volume}% {icon}",
    "format-muted": "ΎΑο",
    "format-bluetooth": "{volume}% {icon} ΎΛΦ",
    "format-icons": {
      "default": ["ΎΑπ", "ΎΑρ"],
      "headphone": "ΎΑξ",
      "hands-free": "ΎΑξ",
      "headset": "Ό╣β",
      "phone": "ΎΓΧ",
      "phone-muted": "Ό┤Ω",
      "portable": "ΎΓΧ",
      "car": "ΎΗ╣",
    },
    "scroll-step": 1,
    "on-click": "pavucontrol",
    "ignored-sinks": ["Easy Effects Sink"],
  },

  "network": {
    "interface": "wlan0",
    "format": "{ifname}",
    "format-wifi": "{essid} ({signalStrength}%) ΎΘτ",
    "format-ethernet": "{ipaddr}/{cidr} ≤░ΛΩ",
    "format-disconnected": "No WiFi ≤░νφ",
    "tooltip-format": "{ifname} via {gwaddr}",
    "tooltip-format-wifi": "{essid} ({signalStrength}%) ΎΘτ",
    "tooltip-format-ethernet": "{ifname} ΎΔΒ",
    "tooltip-format-disconnected": "Disconnected",
    "max-length": 40,
    "on-click": "~/.config/hypr/scripts/wifimananger.sh",
  },

  "battery": {
    "states": {
      "middle": 40,
      "warning": 20,
      "critical": 10,
    },
    "format": "{capacity}% {icon}",
    "format-charging": "{capacity}% ≤▒ΡΜ",
    "format-plugged": "{capacity}% ΎΘο",
    "format-icons": ["ΎΚΕ", "ΎΚΔ", "ΎΚΓ", "ΎΚΒ", "ΎΚΑ"],
  },

  "custom/notifications": {
    "format": "ΎΔ│",
    "tooltip": false,
    "on-click": "swaync-client -t",
  },
}
